{
  "$id": "https://mcp-flowgate.dev/schemas/workflow-response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowResponse",
  "type": "object",
  "required": ["workflow", "result", "links"],
  "additionalProperties": false,
  "properties": {
    "workflow": { "$ref": "#/$defs/workflowSnapshot" },
    "result": { "$ref": "#/$defs/result" },
    "context": { "type": "object" },
    "summary": {
      "type": "string",
      "description": "The optional model-authored summary stored at `context.summary` (SPEC §6.3). Surfaced here so a cold-resuming LLM sees the last narrative without digging through context."
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" },
      "default": []
    },
    "error": { "$ref": "#/$defs/error" },
    "chain": {
      "type": "array",
      "items": { "$ref": "#/$defs/chainStep" },
      "default": [],
      "description": "When deterministic chaining occurred, records each intermediate state the workflow traversed automatically."
    },
    "guidance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goal": { "type": "string" },
        "instructions": { "type": "string" },
        "refs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["verb", "subject"],
            "additionalProperties": false,
            "properties": {
              "verb": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "subject": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
            }
          },
          "default": [],
          "description": "Referenced-tier guidance — a menu of `{verb, subject}` tokens the model can fetch via gateway.describe (SPEC §5.4-§5.5)."
        }
      },
      "description": "Phase-level guidance for the LLM: what to aim for and how to behave in the current workflow state."
    }
  },
  "$defs": {
    "workflowSnapshot": {
      "type": "object",
      "required": ["id", "definitionId", "state", "version"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "definitionId": { "type": "string" },
        "definitionVersion": { "type": "string" },
        "state": { "type": "string" },
        "version": { "type": "integer", "minimum": 0 }
      }
    },
    "result": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "started",
            "waiting_for_action",
            "executed",
            "completed",
            "rejected",
            "failed",
            "timed_out"
          ]
        },
        "message": { "type": "string" }
      }
    },
    "link": {
      "type": "object",
      "required": ["rel", "method", "args"],
      "additionalProperties": false,
      "properties": {
        "rel": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "method": {
          "type": "string",
          "const": "workflow.submit"
        },
        "actor": {
          "type": "string",
          "enum": ["agent", "human", "system", "deterministic"]
        },
        "args": {
          "type": "object",
          "required": ["workflowId", "expectedVersion", "transition"],
          "additionalProperties": false,
          "properties": {
            "workflowId": { "type": "string" },
            "expectedVersion": { "type": "integer", "minimum": 0 },
            "transition": { "type": "string" }
          }
        },
        "inputSchema": { "type": "object" },
        "guidance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "refs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["verb", "subject"],
                "additionalProperties": false,
                "properties": {
                  "verb": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                  "subject": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
                }
              }
            }
          },
          "description": "Link-scoped guidance — references that surface only when this transition is offered (SPEC §5.5 transition-scope skills)."
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "id"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "id": { "type": "string" },
        "uri": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "attemptedTransition": { "type": "string" }
      }
    },
    "chainStep": {
      "type": "object",
      "required": ["fromState", "transition", "toState", "version"],
      "additionalProperties": false,
      "properties": {
        "fromState": { "type": "string" },
        "transition": { "type": "string" },
        "toState": { "type": "string" },
        "version": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
