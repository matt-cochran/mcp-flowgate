---
import Landing from '../../layouts/Landing.astro';

const approvalCode = `<span class="text-indigo-400">states</span>:
  <span class="text-indigo-400">awaiting_approval</span>:
    <span class="text-indigo-400">transitions</span>:
      <span class="text-indigo-400">approve</span>:
        <span class="text-indigo-400">target</span>: <span class="text-green-400">approved</span>
        <span class="text-indigo-400">actor</span>: <span class="text-green-400">human</span>            <span class="text-slate-500"># the LLM cannot take this step</span>
  <span class="text-indigo-400">approved</span>:
    <span class="text-indigo-400">transitions</span>:
      <span class="text-indigo-400">publish</span>:
        <span class="text-indigo-400">target</span>: <span class="text-green-400">published</span>
        <span class="text-indigo-400">guards</span>:
          - { <span class="text-indigo-400">kind</span>: <span class="text-green-400">evidence</span>, <span class="text-indigo-400">requires</span>: [<span class="text-green-400">human_request</span>] }   <span class="text-slate-500"># only after a logged approval</span>
        <span class="text-indigo-400">executor</span>: { <span class="text-indigo-400">kind</span>: <span class="text-green-400">rest</span>, <span class="text-indigo-400">connection</span>: <span class="text-green-400">cms</span>, <span class="text-indigo-400">idempotencyKey</span>: <span class="text-green-400">true</span> }`;
---

<Landing
	title="What do a deploy pipeline and an expense report have in common? — mcp-flowgate"
	description="mcp-flowgate is not an agentic coding tool. Coding is one use case among many — and regulation is fast making the audit trail it produces a requirement."
>

<nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-slate-950/80 border-b border-slate-800">
	<div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
