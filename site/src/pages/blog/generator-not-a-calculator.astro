---
import Landing from '../../layouts/Landing.astro';

const actorCode = `<span class="text-indigo-400">states</span>:
  <span class="text-indigo-400">test</span>:
    <span class="text-indigo-400">transitions</span>:
      <span class="text-indigo-400">run_tests</span>:
        <span class="text-indigo-400">target</span>: <span class="text-green-400">ready_to_ship</span>
        <span class="text-indigo-400">actor</span>: <span class="text-green-400">deterministic</span>     <span class="text-slate-500"># computation — the runtime runs it</span>
        <span class="text-indigo-400">executor</span>: { <span class="text-indigo-400">kind</span>: <span class="text-green-400">cli</span>, <span class="text-indigo-400">command</span>: <span class="text-green-400">test-runner</span> }
  <span class="text-indigo-400">ready_to_ship</span>:
    <span class="text-indigo-400">transitions</span>:
      <span class="text-indigo-400">ship</span>:
        <span class="text-indigo-400">target</span>: <span class="text-green-400">shipped</span>
        <span class="text-indigo-400">actor</span>: <span class="text-green-400">agent</span>             <span class="text-slate-500"># judgment — the LLM decides</span>`;
---

<Landing
	title="Your LLM is a generator, not a calculator — mcp-flowgate"
	description="An LLM does one kind of work: generation. It cannot compute — by design, not by immaturity. Match each job to the tool built for it, and both shine."
>

